# --- Choose your provider ---
# "ollama" (default here — no API key needed, good for local dev) or "anthropic"
LLM_PROVIDER=ollama

# --- Anthropic (required if LLM_PROVIDER=anthropic) ---
# Get a key at https://platform.anthropic.com
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# --- Ollama (required if LLM_PROVIDER=ollama) ---
# Local dev only — make sure Ollama is running and the model is pulled.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# --- GitHub token (optional, user can also supply one per-session in the UI) ---
# Raises the MCP server's GitHub API rate limit from 60 to 5,000 requests/hour.
GITHUB_TOKEN=
