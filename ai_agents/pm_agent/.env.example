# --- Choose your provider ---
# "anthropic" (default, recommended) or "ollama" (for local testing)
LLM_PROVIDER=anthropic

# --- Anthropic (required if LLM_PROVIDER=anthropic) ---
# Get a key at https://platform.anthropic.com
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# --- Ollama (required if LLM_PROVIDER=ollama) ---
# Local dev only — make sure Ollama is running and the model is pulled.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
