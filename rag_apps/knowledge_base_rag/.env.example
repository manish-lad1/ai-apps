# --- Choose your generation provider ---
# "anthropic" (default, recommended) or "ollama" (for local testing)
LLM_PROVIDER=anthropic

# --- Anthropic (required if LLM_PROVIDER=anthropic) ---
# Get a key at https://platform.anthropic.com
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# --- Ollama (required if LLM_PROVIDER=ollama) ---
# Local dev only — prefer a model WITHOUT a thinking/reasoning mode
# (e.g. gemma3, not gemma4) — see the parent project's README for why.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# --- Choose your embedding provider ---
# "voyage" (default, recommended) or "ollama" (for local testing)
EMBEDDING_PROVIDER=voyage

# --- Voyage AI (required if EMBEDDING_PROVIDER=voyage) ---
# Get a key at https://voyageai.com — Anthropic's recommended embedding
# provider for RAG. Free tier covers prototyping and light production use.
VOYAGE_API_KEY=your-key-here
VOYAGE_MODEL=voyage-3

# --- Ollama embeddings (required if EMBEDDING_PROVIDER=ollama) ---
# Local dev only — free, no API key needed.
# Run: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
